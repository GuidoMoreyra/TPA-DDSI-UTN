<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Editar Colección - {{titulo}}</title>
  <link rel="stylesheet" href="/assets/css/main.css">
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar">
    <div class="navbar-container">
      <a href="/" class="navbar-brand">MetaMapa</a>
      <ul class="navbar-nav">
        <li><a href="/hechos" class="nav-link">Explorar Hechos</a></li>
        {{#if user}}
          <li><a href="#" class="nav-link">{{nombre}}</a></li>
          {{#if isAdmin}}
            <li><a href="/admin/solicitudes" class="nav-link active">Panel Admin</a></li>
          {{/if}}
          <li><a href="/logout" class="nav-link btn-outline">Cerrar Sesión</a></li>
        {{else}}
          <li><a href="/login" class="nav-link">Iniciar Sesión</a></li>
          <li><a href="/register" class="nav-link btn-primary">Registrarse</a></li>
        {{/if}}
      </ul>
    </div>
  </nav>

  <!-- Header Section -->
  <div style="background: linear-gradient(135deg, #8b5cf6 0%, #6d28d9 100%); color: white; padding: 2rem 0;">
    <div class="container">
      <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.5rem;">
        <a href="/admin/colecciones/{{id}}" style="color: white; text-decoration: none; font-size: 1.5rem;">←</a>
        <div>
          <h1 style="font-size: 2rem; margin: 0; color: white;">Editar Colección</h1>
          <p style="font-size: 1rem; color: rgba(255,255,255,0.9); margin: 0.5rem 0 0 0;">
            Modifica la información de la colección
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="container" style="padding: 2rem 0;">

    <!-- Navegación del Panel Admin -->
    <div style="margin-bottom: 2rem; display: flex; gap: 1rem; flex-wrap: wrap;">
      <a href="/admin/solicitudes" class="btn btn-outline">📋 Solicitudes</a>
      <a href="/admin/estadisticas" class="btn btn-outline">📊 Estadísticas</a>
      <a href="/admin/colecciones" class="btn btn-outline">📚 Colecciones</a>
    </div>

    <!-- Formulario -->
    <div class="card" style="max-width: 800px; margin: 0 auto;">
      <div class="card-body">

        <div style="background-color: #fef3c7; border-left: 4px solid #f59e0b; padding: 1rem; margin-bottom: 1.5rem; border-radius: 4px;">
          <p style="color: #92400e; margin: 0; font-weight: 500;">
            ⚠️ Los criterios de pertenencia (categoría, localidad, fechas y fuente) no se pueden modificar.
            Solo puedes actualizar el título y descripción.
          </p>
        </div>

        <form method="POST" action="/admin/colecciones/{{id}}/editar">

          <!-- Información Básica -->
          <div style="margin-bottom: 2rem;">
            <h3 style="margin-bottom: 1rem; color: #1f2937; border-bottom: 2px solid #e5e7eb; padding-bottom: 0.5rem;">
              📌 Información Básica
            </h3>

            <div class="form-group">
              <label for="titulo" class="form-label">Título de la Colección *</label>
              <input
                type="text"
                id="titulo"
                name="titulo"
                class="form-input"
                value="{{titulo}}"
                required
              >
            </div>

            <div class="form-group">
              <label for="descripcion" class="form-label">Descripción</label>
              <textarea
                id="descripcion"
                name="descripcion"
                class="form-input"
                rows="3"
              >{{descripcion}}</textarea>
            </div>
          </div>

          <!-- Criterios (solo lectura) -->
          <div style="margin-bottom: 2rem;">
            <h3 style="margin-bottom: 1rem; color: #1f2937; border-bottom: 2px solid #e5e7eb; padding-bottom: 0.5rem;">
              🔒 Criterios de Pertenencia (Solo Lectura)
            </h3>

            <div class="form-group">
              <label class="form-label">Categoría</label>
              <input
                type="text"
                class="form-input"
                value="{{categoria}}"
                disabled
                style="background-color: #f3f4f6; cursor: not-allowed;"
              >
            </div>
          </div>

          <!-- Botones -->
          <div style="display: flex; gap: 1rem; justify-content: flex-end; padding-top: 1.5rem; border-top: 1px solid #e5e7eb;">
            <a href="/admin/colecciones/{{id}}" class="btn btn-outline">Cancelar</a>
            <button type="submit" class="btn btn-primary">Guardar Cambios</button>
          </div>

        </form>
      </div>
    </div>

  </div>
</body>
</html>
