<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Detalle de Solicitud - Panel Admin</title>
  <link rel="stylesheet" href="/assets/css/main.css">
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar">
    <div class="navbar-container">
      <a href="/" class="navbar-brand">MetaMapa</a>
      <ul class="navbar-nav">
        <li><a href="/hechos" class="nav-link">Explorar Hechos</a></li>
        {{#if user}}
          <li><a href="#" class="nav-link">{{nombre}}</a></li>
          {{#if isAdmin}}
            <li><a href="/admin/solicitudes" class="nav-link active">Panel Admin</a></li>
          {{/if}}
          <li><a href="/logout" class="nav-link btn-outline">Cerrar Sesión</a></li>
        {{else}}
          <li><a href="/login" class="nav-link">Iniciar Sesión</a></li>
          <li><a href="/register" class="nav-link btn-primary">Registrarse</a></li>
        {{/if}}
      </ul>
    </div>
  </nav>

  <!-- Header Section -->
  <div style="background: linear-gradient(135deg, #dc2626 0%, #991b1b 100%); color: white; padding: 2rem 0;">
    <div class="container">
      <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.5rem;">
        <a href="/admin/solicitudes" style="color: white; text-decoration: none; font-size: 1.5rem;">←</a>
        <h1 style="font-size: 2rem; margin: 0; color: white;">Detalle de Solicitud</h1>
      </div>
      <p style="font-size: 1rem; color: rgba(255,255,255,0.9); margin: 0;">
        Información completa y acciones de moderación
      </p>
    </div>
  </div>

  <!-- Main Content -->
  <div class="container" style="padding: 2rem 0;">

    <!-- Breadcrumb -->
    <div style="margin-bottom: 1.5rem; color: var(--color-gray-600); font-size: 0.875rem;">
      <a href="/" style="color: var(--color-gray-600);">Inicio</a>
      <span style="margin: 0 0.5rem;">›</span>
      <a href="/admin/solicitudes" style="color: var(--color-gray-600);">Panel Admin</a>
      <span style="margin: 0 0.5rem;">›</span>
      <span style="color: var(--color-gray-900); font-weight: 500;">Solicitud #{{solicitud.id}}</span>
    </div>

    <!-- Card Principal: Estado y Acciones -->
    <div class="card" style="margin-bottom: 2rem;">
      <div class="card-header" style="background-color: var(--color-gray-50); border-bottom: 2px solid var(--color-gray-200);">
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <h2 class="card-title" style="margin: 0;">Solicitud #{{solicitud.id}}</h2>
          <div>
            {{#if isPendiente}}
              <span class="badge" style="background-color: rgba(245, 158, 11, 0.1); color: #f59e0b; padding: 0.75rem 1.5rem; font-size: 1rem; font-weight: 600;">
                ⏳ Pendiente
              </span>
            {{else if isAprobado}}
              <span class="badge" style="background-color: rgba(16, 185, 129, 0.1); color: #10b981; padding: 0.75rem 1.5rem; font-size: 1rem; font-weight: 600;">
                ✓ Aprobada
              </span>
            {{else if isRechazado}}
              <span class="badge" style="background-color: rgba(239, 68, 68, 0.1); color: #ef4444; padding: 0.75rem 1.5rem; font-size: 1rem; font-weight: 600;">
                ✗ Rechazada
              </span>
            {{else if isRechazadoAuto}}
              <span class="badge" style="background-color: rgba(239, 68, 68, 0.1); color: #ef4444; padding: 0.75rem 1.5rem; font-size: 1rem; font-weight: 600;">
                ✗ Rechazada Automáticamente
              </span>
            {{/if}}
          </div>
        </div>
      </div>
      <div class="card-body" style="padding: 2rem;">

        <!-- Detección de Spam -->
        {{#if solicitud.esSpam}}
          <div style="background-color: #fef3c7; border-left: 4px solid #f59e0b; padding: 1rem; margin-bottom: 2rem; border-radius: 4px;">
            <div style="display: flex; align-items: center; gap: 0.75rem;">
              <span style="font-size: 1.5rem;">⚠️</span>
              <div>
                <p style="color: #92400e; margin: 0; font-weight: 600;">Detectado como posible spam</p>
                <p style="color: #92400e; margin: 0.25rem 0 0 0; font-size: 0.875rem;">El sistema de detección identificó patrones sospechosos en esta solicitud.</p>
              </div>
            </div>
          </div>
        {{/if}}

        <!-- Justificación -->
        <div style="margin-bottom: 2rem;">
          <h3 style="color: var(--color-gray-900); font-size: 1.25rem; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">
            <span style="font-size: 1.5rem;">📝</span>
            Justificación del Usuario
          </h3>
          <div style="background-color: var(--color-gray-50); padding: 1.5rem; border-radius: 8px; border-left: 4px solid var(--color-primary);">
            <p style="color: var(--color-gray-800); line-height: 1.6; font-size: 1rem; margin: 0; white-space: pre-wrap;">{{solicitud.justificacion}}</p>
          </div>
          <div style="margin-top: 0.5rem; color: var(--color-gray-600); font-size: 0.875rem;">
            Caracteres: {{solicitud.justificacion.length}}
          </div>
        </div>

        <!-- Acciones de Moderación -->
        {{#if isPendiente}}
          <div style="border-top: 1px solid var(--color-gray-200); padding-top: 2rem;">
            <h3 style="color: var(--color-gray-900); font-size: 1.25rem; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">
              <span style="font-size: 1.5rem;">⚖️</span>
              Acciones de Moderación
            </h3>
            <div style="display: flex; gap: 1rem; align-items: center;">
              <form action="/admin/solicitudes/{{solicitud.id}}/aprobar" method="POST" style="margin: 0;" onsubmit="return confirm('¿Estás seguro de aprobar esta solicitud? El hecho será marcado como inactivo y no será visible públicamente.');">
                <button type="submit" class="btn" style="background-color: #10b981; color: white; border: none; display: flex; align-items: center; gap: 0.5rem;">
                  <span style="font-size: 1.25rem;">✓</span>
                  Aprobar Solicitud
                </button>
              </form>
              <form action="/admin/solicitudes/{{solicitud.id}}/rechazar" method="POST" style="margin: 0;" onsubmit="return confirm('¿Estás seguro de rechazar esta solicitud? El hecho permanecerá activo.');">
                <button type="submit" class="btn" style="background-color: #ef4444; color: white; border: none; display: flex; align-items: center; gap: 0.5rem;">
                  <span style="font-size: 1.25rem;">✗</span>
                  Rechazar Solicitud
                </button>
              </form>
            </div>
          </div>
        {{else}}
          <div style="border-top: 1px solid var(--color-gray-200); padding-top: 2rem;">
            <p style="color: var(--color-gray-600); font-style: italic; margin: 0;">
              Esta solicitud ya fue procesada. No se pueden realizar más acciones.
            </p>
          </div>
        {{/if}}
      </div>
    </div>

    <!-- Card del Hecho Asociado -->
    <div class="card">
      <div class="card-header" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border-bottom: none;">
        <h3 class="card-title" style="margin: 0; color: white;">Hecho Reportado</h3>
      </div>
      <div class="card-body" style="padding: 2rem;">

        <!-- Título y Categoría -->
        <div style="margin-bottom: 2rem;">
          <h2 style="color: var(--color-gray-900); font-size: 1.75rem; margin-bottom: 0.5rem;">
            {{hecho.titulo}}
          </h2>
          <span class="badge" style="background-color: rgba(102, 126, 234, 0.1); color: #667eea; font-size: 0.875rem; padding: 0.5rem 1rem;">
            {{hecho.categoria}}
          </span>
        </div>

        <!-- Descripción -->
        <div style="margin-bottom: 2rem;">
          <h4 style="color: var(--color-gray-700); font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 0.75rem;">
            Descripción
          </h4>
          <p style="color: var(--color-gray-800); line-height: 1.6; font-size: 1rem; margin: 0; text-align: justify;">
            {{hecho.descripcion}}
          </p>
        </div>

        <!-- Grid de información -->
        <div class="grid grid-cols-2" style="gap: 1.5rem;">

          <!-- Columna Izquierda -->
          <div>
            <!-- Fecha del Hecho -->
            <div style="margin-bottom: 1rem; padding: 1rem; background-color: var(--color-gray-50); border-radius: 8px;">
              <div style="color: var(--color-gray-700); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 0.25rem;">
                Fecha del Hecho
              </div>
              <div style="color: var(--color-gray-900); font-size: 1rem; font-weight: 600;">
                {{hecho.fechaDelHecho}}
              </div>
            </div>

            <!-- Origen -->
            <div style="padding: 1rem; background-color: var(--color-gray-50); border-radius: 8px;">
              <div style="color: var(--color-gray-700); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 0.25rem;">
                Origen
              </div>
              <div style="color: var(--color-gray-900); font-size: 1rem; font-weight: 600;">
                {{hecho.origen}}
              </div>
            </div>
          </div>

          <!-- Columna Derecha -->
          <div>
            <!-- Ubicación -->
            <div style="margin-bottom: 1rem; padding: 1rem; background-color: var(--color-gray-50); border-radius: 8px;">
              <div style="color: var(--color-gray-700); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 0.25rem;">
                Ubicación
              </div>
              <div style="color: var(--color-gray-900); font-size: 1rem; font-weight: 600;">
                {{#if hecho.provincia}}{{hecho.provincia}}{{else}}No especificada{{/if}}
              </div>
              {{#if hecho.coordenadas.localidad}}
                <div style="color: var(--color-gray-600); font-size: 0.875rem; margin-top: 0.25rem;">
                  {{hecho.coordenadas.localidad}}
                </div>
              {{/if}}
            </div>

            <!-- Coordenadas -->
            <div style="padding: 1rem; background-color: var(--color-gray-50); border-radius: 8px;">
              <div style="color: var(--color-gray-700); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 0.25rem;">
                Coordenadas
              </div>
              <div style="color: var(--color-gray-900); font-size: 0.875rem;">
                Lat: {{hecho.coordenadas.latitud}}, Lng: {{hecho.coordenadas.longitud}}
              </div>
            </div>
          </div>
        </div>

        <!-- Link al hecho -->
        <div style="margin-top: 2rem; padding-top: 2rem; border-top: 1px solid var(--color-gray-200);">
          <a href="/hechos/{{hecho.id}}" class="btn btn-outline" target="_blank">
            Ver Hecho Completo →
          </a>
        </div>
      </div>
    </div>

    <!-- Botón Volver -->
    <div style="margin-top: 2rem;">
      <a href="/admin/solicitudes" class="btn btn-outline">← Volver al Panel Admin</a>
    </div>

  </div>

  <!-- Footer -->
  <div style="background-color: var(--color-gray-800); color: white; padding: 2rem 0; margin-top: 3rem;">
    <div class="container" style="text-align: center;">
      <p style="margin: 0;">MetaMapa - Sistema de gestión de mapeos colaborativos</p>
      <p style="margin: 0.5rem 0 0 0; color: var(--color-gray-400); font-size: 0.875rem;">
        Desarrollado para UTN - Diseño de Sistemas - 2025
      </p>
    </div>
  </div>
</body>
</html>
