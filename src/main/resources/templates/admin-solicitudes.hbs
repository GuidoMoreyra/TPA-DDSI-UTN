<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Panel Admin - Solicitudes de Eliminación</title>
  <link rel="stylesheet" href="/assets/css/main.css">
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar">
    <div class="navbar-container">
      <a href="/" class="navbar-brand">MetaMapa</a>
      <ul class="navbar-nav">
        <li><a href="/hechos" class="nav-link">Explorar Hechos</a></li>
        {{#if user}}
          <li><a href="#" class="nav-link">{{nombre}}</a></li>
          {{#if isAdmin}}
            <li><a href="/admin/solicitudes" class="nav-link active">Panel Admin</a></li>
          {{/if}}
          <li><a href="/logout" class="nav-link btn-outline">Cerrar Sesión</a></li>
        {{else}}
          <li><a href="/login" class="nav-link">Iniciar Sesión</a></li>
          <li><a href="/register" class="nav-link btn-primary">Registrarse</a></li>
        {{/if}}
      </ul>
    </div>
  </nav>

  <!-- Header Section -->
  <div style="background: linear-gradient(135deg, #dc2626 0%, #991b1b 100%); color: white; padding: 2rem 0;">
    <div class="container">
      <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.5rem;">
        <span style="font-size: 2.5rem;">🛡️</span>
        <h1 style="font-size: 2rem; margin: 0; color: white;">Panel de Administración</h1>
      </div>
      <p style="font-size: 1rem; color: rgba(255,255,255,0.9); margin: 0;">
        Gestión de solicitudes de eliminación de hechos
      </p>
    </div>
  </div>

  <!-- Main Content -->
  <div class="container" style="padding: 2rem 0;">

    <!-- Navegación del Panel Admin -->
    <div style="margin-bottom: 2rem; display: flex; gap: 1rem; flex-wrap: wrap;">
      <a href="/admin/solicitudes" class="btn btn-primary" style="pointer-events: none;">📋 Solicitudes</a>
      <a href="/admin/estadisticas" class="btn btn-outline">📊 Estadísticas</a>
    </div>

    <!-- Mensajes de feedback -->
    {{#if mensajeAprobada}}
      <div style="background-color: #d1fae5; border-left: 4px solid #10b981; padding: 1rem; margin-bottom: 1.5rem; border-radius: 4px;">
        <p style="color: #065f46; margin: 0; font-weight: 500;">✓ Solicitud aprobada correctamente. El hecho ha sido marcado como inactivo.</p>
      </div>
    {{/if}}
    {{#if mensajeRechazada}}
      <div style="background-color: #fee2e2; border-left: 4px solid #ef4444; padding: 1rem; margin-bottom: 1.5rem; border-radius: 4px;">
        <p style="color: #991b1b; margin: 0; font-weight: 500;">✓ Solicitud rechazada correctamente.</p>
      </div>
    {{/if}}
    {{#if error}}
      <div style="background-color: #fee2e2; border-left: 4px solid #ef4444; padding: 1rem; margin-bottom: 1.5rem; border-radius: 4px;">
        <p style="color: #991b1b; margin: 0; font-weight: 500;">✗ Error al procesar la solicitud. Intente nuevamente.</p>
      </div>
    {{/if}}

    <!-- Estadísticas -->
    <div class="grid grid-cols-4" style="gap: 1rem; margin-bottom: 2rem;">
      <!-- Total -->
      <div class="card" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none;">
        <div class="card-body" style="text-align: center; padding: 1.5rem;">
          <div style="font-size: 2.5rem; font-weight: bold; margin-bottom: 0.5rem;">{{totalSolicitudes}}</div>
          <div style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.5px; opacity: 0.9;">Total Solicitudes</div>
        </div>
      </div>

      <!-- Pendientes -->
      <div class="card" style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); color: white; border: none;">
        <div class="card-body" style="text-align: center; padding: 1.5rem;">
          <div style="font-size: 2.5rem; font-weight: bold; margin-bottom: 0.5rem;">{{pendientes}}</div>
          <div style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.5px; opacity: 0.9;">Pendientes</div>
        </div>
      </div>

      <!-- Aprobadas -->
      <div class="card" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); color: white; border: none;">
        <div class="card-body" style="text-align: center; padding: 1.5rem;">
          <div style="font-size: 2.5rem; font-weight: bold; margin-bottom: 0.5rem;">{{aprobadas}}</div>
          <div style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.5px; opacity: 0.9;">Aprobadas</div>
        </div>
      </div>

      <!-- Rechazadas -->
      <div class="card" style="background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); color: white; border: none;">
        <div class="card-body" style="text-align: center; padding: 1.5rem;">
          <div style="font-size: 2.5rem; font-weight: bold; margin-bottom: 0.5rem;">{{rechazadas}}</div>
          <div style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.5px; opacity: 0.9;">Rechazadas</div>
        </div>
      </div>
    </div>

    <!-- Filtros -->
    <div class="card" style="margin-bottom: 2rem;">
      <div class="card-body" style="padding: 1.5rem;">
        <form method="GET" action="/admin/solicitudes" style="display: flex; align-items: center; gap: 1rem;">
          <label for="estado" style="font-weight: 500; color: var(--color-gray-700); white-space: nowrap;">
            Filtrar por estado:
          </label>
          <select name="estado" id="estado" class="form-input" style="flex: 1; max-width: 300px;" onchange="this.form.submit()">
            <option value="todas" {{#if filtroTodas}}selected{{/if}}>Todas las solicitudes</option>
            <option value="pendiente" {{#if filtroPendiente}}selected{{/if}}>Pendientes ({{pendientes}})</option>
            <option value="aprobado" {{#if filtroAprobado}}selected{{/if}}>Aprobadas ({{aprobadas}})</option>
            <option value="rechazado" {{#if filtroRechazado}}selected{{/if}}>Rechazadas ({{rechazadas}})</option>
          </select>
          {{#unless filtroTodas}}
            <a href="/admin/solicitudes" class="btn btn-outline" style="white-space: nowrap;">Limpiar filtros</a>
          {{/unless}}
        </form>
      </div>
    </div>

    <!-- Tabla de Solicitudes -->
    <div class="card">
      <div class="card-header">
        <h3 class="card-title" style="margin: 0;">
          {{#if filtroPendiente}}
            Solicitudes Pendientes
          {{else if filtroAprobado}}
            Solicitudes Aprobadas
          {{else if filtroRechazado}}
            Solicitudes Rechazadas
          {{else}}
            Todas las Solicitudes
          {{/if}}
        </h3>
      </div>
      <div class="card-body" style="padding: 0;">
        {{#if solicitudes}}
          <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse;">
              <thead style="background-color: var(--color-gray-50); border-bottom: 2px solid var(--color-gray-200);">
                <tr>
                  <th style="padding: 1rem; text-align: left; font-size: 0.875rem; font-weight: 600; color: var(--color-gray-700); text-transform: uppercase; letter-spacing: 0.5px;">
                    Hecho
                  </th>
                  <th style="padding: 1rem; text-align: left; font-size: 0.875rem; font-weight: 600; color: var(--color-gray-700); text-transform: uppercase; letter-spacing: 0.5px; width: 120px;">
                    Estado
                  </th>
                  <th style="padding: 1rem; text-align: left; font-size: 0.875rem; font-weight: 600; color: var(--color-gray-700); text-transform: uppercase; letter-spacing: 0.5px;">
                    Justificación
                  </th>
                  <th style="padding: 1rem; text-align: center; font-size: 0.875rem; font-weight: 600; color: var(--color-gray-700); text-transform: uppercase; letter-spacing: 0.5px; width: 100px;">
                    Spam
                  </th>
                  <th style="padding: 1rem; text-align: right; font-size: 0.875rem; font-weight: 600; color: var(--color-gray-700); text-transform: uppercase; letter-spacing: 0.5px; width: 150px;">
                    Acciones
                  </th>
                </tr>
              </thead>
              <tbody>
                {{#each solicitudes}}
                  <tr style="border-bottom: 1px solid var(--color-gray-200); transition: background-color 0.2s;" onmouseover="this.style.backgroundColor='var(--color-gray-50)'" onmouseout="this.style.backgroundColor='white'">
                    <!-- Hecho -->
                    <td style="padding: 1rem;">
                      <div style="font-weight: 600; color: var(--color-gray-900); margin-bottom: 0.25rem;">
                        {{hecho.titulo}}
                      </div>
                      <div style="font-size: 0.875rem; color: var(--color-gray-600);">
                        <span class="badge" style="background-color: rgba(102, 126, 234, 0.1); color: #667eea; font-size: 0.75rem;">
                          {{hecho.categoria}}
                        </span>
                      </div>
                    </td>

                    <!-- Estado -->
                    <td style="padding: 1rem;">
                      {{#if isPendiente}}
                        <span class="badge" style="background-color: rgba(245, 158, 11, 0.1); color: #f59e0b; padding: 0.5rem 1rem; font-weight: 600;">
                          Pendiente
                        </span>
                      {{else if isAprobado}}
                        <span class="badge" style="background-color: rgba(16, 185, 129, 0.1); color: #10b981; padding: 0.5rem 1rem; font-weight: 600;">
                          Aprobada
                        </span>
                      {{else if isRechazado}}
                        <span class="badge" style="background-color: rgba(239, 68, 68, 0.1); color: #ef4444; padding: 0.5rem 1rem; font-weight: 600;">
                          Rechazada
                        </span>
                      {{else if isRechazadoAuto}}
                        <span class="badge" style="background-color: rgba(239, 68, 68, 0.1); color: #ef4444; padding: 0.5rem 1rem; font-weight: 600;">
                          Rechazada (Auto)
                        </span>
                      {{/if}}
                    </td>

                    <!-- Justificación -->
                    <td style="padding: 1rem;">
                      <div style="color: var(--color-gray-700); font-size: 0.875rem; line-height: 1.4;">
                        {{justificacionTruncada}}
                      </div>
                    </td>

                    <!-- Spam -->
                    <td style="padding: 1rem; text-align: center;">
                      {{#if esSpam}}
                        <span style="font-size: 1.5rem;" title="Detectado como spam">⚠️</span>
                      {{else}}
                        <span style="font-size: 1.5rem; opacity: 0.3;" title="No es spam">✓</span>
                      {{/if}}
                    </td>

                    <!-- Acciones -->
                    <td style="padding: 1rem; text-align: right;">
                      <a href="/admin/solicitudes/{{id}}" class="btn btn-primary" style="font-size: 0.875rem; padding: 0.5rem 1rem; white-space: nowrap;">
                        Ver Detalle
                      </a>
                    </td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
        {{else}}
          <div style="padding: 3rem; text-align: center; color: var(--color-gray-500);">
            <div style="font-size: 3rem; margin-bottom: 1rem;">📭</div>
            <p style="font-size: 1.125rem; font-weight: 500; margin-bottom: 0.5rem;">No hay solicitudes para mostrar</p>
            <p style="font-size: 0.875rem; margin: 0;">
              {{#if filtroTodas}}
                Aún no se han recibido solicitudes de eliminación.
              {{else}}
                No hay solicitudes con este estado.
              {{/if}}
            </p>
          </div>
        {{/if}}
      </div>
    </div>

  </div>

  <!-- Footer -->
  <div style="background-color: var(--color-gray-800); color: white; padding: 2rem 0; margin-top: 3rem;">
    <div class="container" style="text-align: center;">
      <p style="margin: 0;">MetaMapa - Sistema de gestión de mapeos colaborativos</p>
      <p style="margin: 0.5rem 0 0 0; color: var(--color-gray-400); font-size: 0.875rem;">
        Desarrollado para UTN - Diseño de Sistemas - 2025
      </p>
    </div>
  </div>
</body>
</html>
