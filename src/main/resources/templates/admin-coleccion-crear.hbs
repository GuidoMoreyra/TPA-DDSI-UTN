<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Panel Admin - Crear Colección</title>
  <link rel="stylesheet" href="/assets/css/main.css">
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar">
    <div class="navbar-container">
      <a href="/" class="navbar-brand">MetaMapa</a>
      <ul class="navbar-nav">
        <li><a href="/hechos" class="nav-link">Explorar Hechos</a></li>
        {{#if user}}
          <li><a href="#" class="nav-link">{{nombre}}</a></li>
          {{#if isAdmin}}
            <li><a href="/admin/solicitudes" class="nav-link active">Panel Admin</a></li>
          {{/if}}
          <li><a href="/logout" class="nav-link btn-outline">Cerrar Sesión</a></li>
        {{else}}
          <li><a href="/login" class="nav-link">Iniciar Sesión</a></li>
          <li><a href="/register" class="nav-link btn-primary">Registrarse</a></li>
        {{/if}}
      </ul>
    </div>
  </nav>

  <!-- Header Section -->
  <div style="background: linear-gradient(135deg, #8b5cf6 0%, #6d28d9 100%); color: white; padding: 2rem 0;">
    <div class="container">
      <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.5rem;">
        <span style="font-size: 2.5rem;">📚</span>
        <h1 style="font-size: 2rem; margin: 0; color: white;">Crear Nueva Colección</h1>
      </div>
      <p style="font-size: 1rem; color: rgba(255,255,255,0.9); margin: 0;">
        Define los criterios para organizar hechos en una colección
      </p>
    </div>
  </div>

  <!-- Main Content -->
  <div class="container" style="padding: 2rem 0;">

    <!-- Navegación del Panel Admin -->
    <div style="margin-bottom: 2rem; display: flex; gap: 1rem; flex-wrap: wrap;">
      <a href="/admin/solicitudes" class="btn btn-outline">📋 Solicitudes</a>
      <a href="/admin/estadisticas" class="btn btn-outline">📊 Estadísticas</a>
      <a href="/admin/colecciones" class="btn btn-outline">📚 Colecciones</a>
    </div>

    <!-- Formulario -->
    <div class="card" style="max-width: 800px; margin: 0 auto;">
      <div class="card-body">
        <form method="POST" action="/admin/colecciones/crear">

          <!-- Información Básica -->
          <div style="margin-bottom: 2rem;">
            <h3 style="margin-bottom: 1rem; color: #1f2937; border-bottom: 2px solid #e5e7eb; padding-bottom: 0.5rem;">
              📌 Información Básica
            </h3>

            <div class="form-group">
              <label for="titulo" class="form-label">Título de la Colección *</label>
              <input
                type="text"
                id="titulo"
                name="titulo"
                class="form-input"
                placeholder="Ej: Incendios forestales en Argentina 2025"
                required
              >
              <small style="color: #6b7280; display: block; margin-top: 0.25rem;">
                Un título descriptivo que identifique claramente la colección
              </small>
            </div>

            <div class="form-group">
              <label for="descripcion" class="form-label">Descripción</label>
              <textarea
                id="descripcion"
                name="descripcion"
                class="form-input"
                rows="3"
                placeholder="Describe el propósito y alcance de esta colección..."
              ></textarea>
            </div>
          </div>

          <!-- Fuente de Datos -->
          <div style="margin-bottom: 2rem;">
            <h3 style="margin-bottom: 1rem; color: #1f2937; border-bottom: 2px solid #e5e7eb; padding-bottom: 0.5rem;">
              🔗 Fuente de Datos
            </h3>

            <div class="form-group">
              <label for="fuenteId" class="form-label">Fuente *</label>
              <select id="fuenteId" name="fuenteId" class="form-input" required>
                <option value="">Selecciona una fuente...</option>
                {{#each fuentes}}
                  <option value="{{id}}">{{nombre}}</option>
                {{/each}}
              </select>
              <small style="color: #6b7280; display: block; margin-top: 0.25rem;">
                La fuente de donde se obtendrán los hechos para esta colección
              </small>
            </div>
          </div>

          <!-- Criterios de Pertenencia -->
          <div style="margin-bottom: 2rem;">
            <h3 style="margin-bottom: 1rem; color: #1f2937; border-bottom: 2px solid #e5e7eb; padding-bottom: 0.5rem;">
              🎯 Criterios de Pertenencia
            </h3>
            <p style="color: #6b7280; font-size: 0.95rem; margin-bottom: 1rem;">
              Define los criterios que debe cumplir un hecho para pertenecer a esta colección
            </p>

            <div class="form-group">
              <label for="categoria" class="form-label">Categoría *</label>
              <select id="categoria" name="categoria" class="form-input" required>
                <option value="">Selecciona una categoría...</option>
                {{#each categorias}}
                  <option value="{{this}}">{{this}}</option>
                {{/each}}
              </select>
              <small style="color: #6b7280; display: block; margin-top: 0.25rem;">
                Solo se incluirán hechos de esta categoría
              </small>
            </div>

            <div class="form-group">
              <label for="localidad" class="form-label">Localidad / País</label>
              <input
                type="text"
                id="localidad"
                name="localidad"
                class="form-input"
                placeholder="Ej: Argentina"
              >
              <small style="color: #6b7280; display: block; margin-top: 0.25rem;">
                Filtrar por ubicación geográfica (opcional)
              </small>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
              <div class="form-group">
                <label for="fechaInicial" class="form-label">Fecha Inicial *</label>
                <input
                  type="date"
                  id="fechaInicial"
                  name="fechaInicial"
                  class="form-input"
                  required
                >
              </div>

              <div class="form-group">
                <label for="fechaFinal" class="form-label">Fecha Final *</label>
                <input
                  type="date"
                  id="fechaFinal"
                  name="fechaFinal"
                  class="form-input"
                  required
                >
              </div>
            </div>
            <small style="color: #6b7280; display: block; margin-top: 0.25rem;">
              Rango de fechas para los hechos incluidos en la colección
            </small>
          </div>

          <!-- Botones -->
          <div style="display: flex; gap: 1rem; justify-content: flex-end; padding-top: 1.5rem; border-top: 1px solid #e5e7eb;">
            <a href="/admin/colecciones" class="btn btn-outline">Cancelar</a>
            <button type="submit" class="btn btn-primary">Crear Colección</button>
          </div>

        </form>
      </div>
    </div>

  </div>
</body>
</html>
