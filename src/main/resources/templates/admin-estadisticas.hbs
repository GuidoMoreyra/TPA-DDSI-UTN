<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Estadísticas - Panel Admin</title>
  <link rel="stylesheet" href="/assets/css/main.css">
  <style>
    .stat-card {
      background: white;
      border-radius: 12px;
      padding: 1.5rem;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .stat-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 12px rgba(0, 0, 0, 0.15);
    }
    .stat-number {
      font-size: 2.5rem;
      font-weight: bold;
      margin: 0.5rem 0;
    }
    .stat-label {
      font-size: 0.875rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--color-gray-600);
      font-weight: 600;
    }
    .bar-chart {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .bar-item {
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .bar-label {
      min-width: 150px;
      font-weight: 500;
      color: var(--color-gray-700);
    }
    .bar-container {
      flex: 1;
      height: 32px;
      background: var(--color-gray-100);
      border-radius: 6px;
      overflow: hidden;
      position: relative;
    }
    .bar-fill {
      height: 100%;
      background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
      transition: width 0.6s ease-out;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding-right: 0.5rem;
      color: white;
      font-weight: 600;
      font-size: 0.875rem;
    }
    .bar-value {
      min-width: 60px;
      text-align: right;
      font-weight: 600;
      color: var(--color-gray-700);
    }
    .progress-ring {
      width: 120px;
      height: 120px;
      margin: 0 auto;
    }
    .progress-ring-circle {
      transition: stroke-dashoffset 0.6s ease-out;
      transform: rotate(-90deg);
      transform-origin: 50% 50%;
    }
  </style>
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar">
    <div class="navbar-container">
      <a href="/" class="navbar-brand">MetaMapa</a>
      <ul class="navbar-nav">
        <li><a href="/hechos" class="nav-link">Explorar Hechos</a></li>
        {{#if user}}
          <li><a href="#" class="nav-link">{{nombre}}</a></li>
          {{#if isAdmin}}
            <li><a href="/admin/solicitudes" class="nav-link">Panel Admin</a></li>
          {{/if}}
          <li><a href="/logout" class="nav-link btn-outline">Cerrar Sesión</a></li>
        {{else}}
          <li><a href="/login" class="nav-link">Iniciar Sesión</a></li>
          <li><a href="/register" class="nav-link btn-primary">Registrarse</a></li>
        {{/if}}
      </ul>
    </div>
  </nav>

  <!-- Header Section -->
  <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 2rem 0;">
    <div class="container">
      <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.5rem;">
        <span style="font-size: 2.5rem;">📊</span>
        <h1 style="font-size: 2rem; margin: 0; color: white;">Estadísticas del Sistema</h1>
      </div>
      <p style="font-size: 1rem; color: rgba(255,255,255,0.9); margin: 0;">
        Análisis y métricas de la plataforma MetaMapa
      </p>
    </div>
  </div>

  <!-- Main Content -->
  <div class="container" style="padding: 2rem 0;">

    <!-- Navegación del Panel Admin -->
    <div style="margin-bottom: 2rem; display: flex; gap: 1rem; flex-wrap: wrap;">
      <a href="/admin/solicitudes" class="btn btn-outline">📋 Solicitudes</a>
      <a href="/admin/estadisticas" class="btn btn-primary" style="pointer-events: none;">📊 Estadísticas</a>
      <a href="/admin/colecciones" class="btn btn-outline">📚 Colecciones</a>
    </div>

    {{#if error}}
      <div style="background-color: #fee2e2; border-left: 4px solid #ef4444; padding: 1rem; margin-bottom: 1.5rem; border-radius: 4px;">
        <p style="color: #991b1b; margin: 0; font-weight: 500;">✗ {{error}}</p>
      </div>
    {{/if}}

    <!-- Resumen General -->
    <h2 style="color: var(--color-gray-900); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
      <span>📈</span>
      Resumen General
    </h2>

    <div class="grid grid-cols-4" style="gap: 1.5rem; margin-bottom: 3rem;">
      <!-- Total Hechos -->
      <div class="stat-card" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
        <div class="stat-label" style="color: rgba(255,255,255,0.9);">Total Hechos</div>
        <div class="stat-number">{{totalHechos}}</div>
        <div style="font-size: 0.875rem; opacity: 0.9;">En la base de datos</div>
      </div>

      <!-- Hechos Activos -->
      <div class="stat-card" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); color: white;">
        <div class="stat-label" style="color: rgba(255,255,255,0.9);">Hechos Activos</div>
        <div class="stat-number">{{hechosActivos}}</div>
        <div style="font-size: 0.875rem; opacity: 0.9;">Visibles en el sistema</div>
      </div>

      <!-- Hechos Inactivos -->
      <div class="stat-card" style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); color: white;">
        <div class="stat-label" style="color: rgba(255,255,255,0.9);">Hechos Inactivos</div>
        <div class="stat-number">{{hechosInactivos}}</div>
        <div style="font-size: 0.875rem; opacity: 0.9;">Eliminados o archivados</div>
      </div>

      <!-- Total Solicitudes -->
      <div class="stat-card" style="background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); color: white;">
        <div class="stat-label" style="color: rgba(255,255,255,0.9);">Solicitudes</div>
        <div class="stat-number">{{totalSolicitudes}}</div>
        <div style="font-size: 0.875rem; opacity: 0.9;">De eliminación totales</div>
      </div>
    </div>

    <!-- Distribución por Categoría -->
    <div class="grid grid-cols-2" style="gap: 2rem; margin-bottom: 3rem;">
      <!-- Gráfico de Categorías -->
      <div class="card">
        <div class="card-header">
          <h3 class="card-title" style="margin: 0;">📚 Top 5 Categorías</h3>
        </div>
        <div class="card-body">
          {{#if distribucionCategorias}}
            <div class="bar-chart">
              {{#each distribucionCategorias}}
                <div class="bar-item">
                  <div class="bar-label">{{nombre}}</div>
                  <div class="bar-container">
                    <div class="bar-fill" style="width: {{porcentaje}}%;"></div>
                  </div>
                  <div class="bar-value">{{cantidad}}</div>
                </div>
              {{/each}}
            </div>
          {{else}}
            <p style="text-align: center; color: var(--color-gray-500); padding: 2rem;">No hay datos disponibles</p>
          {{/if}}
        </div>
      </div>

      <!-- Gráfico de Provincias -->
      <div class="card">
        <div class="card-header">
          <h3 class="card-title" style="margin: 0;">🗺️ Top 5 Provincias</h3>
        </div>
        <div class="card-body">
          {{#if distribucionProvincias}}
            <div class="bar-chart">
              {{#each distribucionProvincias}}
                <div class="bar-item">
                  <div class="bar-label">{{nombre}}</div>
                  <div class="bar-container">
                    <div class="bar-fill" style="width: {{percentage}}%;"></div>
                  </div>
                  <div class="bar-value">{{cantidad}}</div>
                </div>
              {{/each}}
            </div>
          {{else}}
            <p style="text-align: center; color: var(--color-gray-500); padding: 2rem;">No hay datos disponibles</p>
          {{/if}}
        </div>
      </div>
    </div>

    <!-- Estadísticas de Solicitudes -->
    <h2 style="color: var(--color-gray-900); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
      <span>📋</span>
      Solicitudes de Eliminación
    </h2>

    <div class="grid grid-cols-3" style="gap: 1.5rem; margin-bottom: 3rem;">
      <!-- Pendientes -->
      <div class="card" style="border-left: 4px solid #f59e0b;">
        <div class="card-body" style="text-align: center; padding: 2rem;">
          <div style="font-size: 3rem; margin-bottom: 0.5rem;">{{solicitudesPendientes}}</div>
          <div style="font-size: 1rem; color: var(--color-gray-700); font-weight: 500; margin-bottom: 0.5rem;">Pendientes</div>
          <div style="font-size: 0.875rem; color: var(--color-gray-500);">Esperando revisión</div>
        </div>
      </div>

      <!-- Aprobadas -->
      <div class="card" style="border-left: 4px solid #10b981;">
        <div class="card-body" style="text-align: center; padding: 2rem;">
          <div style="font-size: 3rem; margin-bottom: 0.5rem;">{{solicitudesAprobadas}}</div>
          <div style="font-size: 1rem; color: var(--color-gray-700); font-weight: 500; margin-bottom: 0.5rem;">Aprobadas</div>
          <div style="font-size: 0.875rem; color: var(--color-gray-500);">Hechos eliminados</div>
        </div>
      </div>

      <!-- Rechazadas -->
      <div class="card" style="border-left: 4px solid #ef4444;">
        <div class="card-body" style="text-align: center; padding: 2rem;">
          <div style="font-size: 3rem; margin-bottom: 0.5rem;">{{solicitudesRechazadas}}</div>
          <div style="font-size: 1rem; color: var(--color-gray-700); font-weight: 500; margin-bottom: 0.5rem;">Rechazadas</div>
          <div style="font-size: 0.875rem; color: var(--color-gray-500);">Incluye auto-rechazadas</div>
        </div>
      </div>
    </div>

    <!-- Datos Destacados -->
    <h2 style="color: var(--color-gray-900); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
      <span>⭐</span>
      Datos Destacados
    </h2>

    <div class="grid grid-cols-3" style="gap: 1.5rem;">
      <!-- Categoría con más hechos -->
      <div class="card">
        <div class="card-body" style="padding: 2rem;">
          <div style="text-align: center; margin-bottom: 1rem;">
            <span style="font-size: 3rem;">🏆</span>
          </div>
          <div style="text-align: center;">
            <div style="font-size: 0.875rem; color: var(--color-gray-600); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 0.5rem;">Categoría Más Popular</div>
            <div style="font-size: 1.5rem; font-weight: bold; color: #667eea;">
              {{#if categoriaConMasHechos}}
                {{categoriaConMasHechos}}
              {{else}}
                N/A
              {{/if}}
            </div>
          </div>
        </div>
      </div>

      <!-- Provincia con más hechos -->
      <div class="card">
        <div class="card-body" style="padding: 2rem;">
          <div style="text-align: center; margin-bottom: 1rem;">
            <span style="font-size: 3rem;">📍</span>
          </div>
          <div style="text-align: center;">
            <div style="font-size: 0.875rem; color: var(--color-gray-600); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 0.5rem;">Provincia Más Activa</div>
            <div style="font-size: 1.5rem; font-weight: bold; color: #10b981;">
              {{#if provinciaConMasHechos}}
                {{provinciaConMasHechos}}
              {{else}}
                N/A
              {{/if}}
            </div>
          </div>
        </div>
      </div>

      <!-- Solicitudes Spam -->
      <div class="card">
        <div class="card-body" style="padding: 2rem;">
          <div style="text-align: center; margin-bottom: 1rem;">
            <span style="font-size: 3rem;">⚠️</span>
          </div>
          <div style="text-align: center;">
            <div style="font-size: 0.875rem; color: var(--color-gray-600); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 0.5rem;">Solicitudes Spam Detectadas</div>
            <div style="font-size: 1.5rem; font-weight: bold; color: #ef4444;">
              {{cantidadSolicitudesSpam}}
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>

  <!-- Footer -->
  <div style="background-color: var(--color-gray-800); color: white; padding: 2rem 0; margin-top: 3rem;">
    <div class="container" style="text-align: center;">
      <p style="margin: 0;">MetaMapa - Sistema de gestión de mapeos colaborativos</p>
      <p style="margin: 0.5rem 0 0 0; color: var(--color-gray-400); font-size: 0.875rem;">
        Desarrollado para UTN - Diseño de Sistemas - 2025
      </p>
    </div>
  </div>

  <script>
    // Animar las barras al cargar
    document.addEventListener('DOMContentLoaded', function() {
      const bars = document.querySelectorAll('.bar-fill');
      bars.forEach(bar => {
        const width = bar.style.width;
        bar.style.width = '0%';
        setTimeout(() => {
          bar.style.width = width;
        }, 100);
      });

      // Calcular porcentajes para provincias (basado en el máximo)
      const provinciaBars = document.querySelectorAll('.distribucionProvincias .bar-fill');
      if (provinciaBars.length > 0) {
        const maxValue = Math.max(...Array.from(provinciaBars).map(bar =>
          parseInt(bar.nextElementSibling.textContent)
        ));

        provinciaBars.forEach(bar => {
          const value = parseInt(bar.nextElementSibling.textContent);
          const percentage = (value / maxValue) * 100;
          bar.style.width = percentage + '%';
          if (percentage > 15) {
            bar.textContent = value;
          }
        });
      }
    });
  </script>
</body>
</html>
