<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{hecho.titulo}} - MetaMapa</title>
  <link rel="stylesheet" href="/assets/css/main.css">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
        integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
        crossorigin=""/>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
          integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
          crossorigin=""></script>
  <style>
    #detailMap {
      height: 300px;
      width: 100%;
      border-radius: 8px;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }
  </style>
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar">
    <div class="navbar-container">
      <a href="/" class="navbar-brand">MetaMapa</a>
      <ul class="navbar-nav">
        <li><a href="/hechos" class="nav-link active">Explorar Hechos</a></li>
        {{#if user}}
          <li><a href="#" class="nav-link">{{nombre}}</a></li>
          {{#if isAdmin}}
            <li><a href="/admin" class="nav-link">Panel Admin</a></li>
          {{/if}}
          <li><a href="/logout" class="nav-link btn-outline">Cerrar Sesión</a></li>
        {{else}}
          <li><a href="/login" class="nav-link">Iniciar Sesión</a></li>
          <li><a href="/register" class="nav-link btn-primary">Registrarse</a></li>
        {{/if}}
      </ul>
    </div>
  </nav>

  <!-- Header Section -->
  <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 2rem 0;">
    <div class="container">
      <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.5rem;">
        <a href="/hechos" style="color: white; text-decoration: none; font-size: 1.5rem;">←</a>
        <h1 style="font-size: 2rem; margin: 0; color: white;">Detalle del Hecho</h1>
      </div>
      <p style="font-size: 1rem; color: rgba(255,255,255,0.9); margin: 0;">
        Información completa sobre este hecho histórico, cultural o turístico
      </p>
    </div>
  </div>

  <!-- Main Content -->
  <div class="container" style="padding: 2rem 0;">

    <!-- Breadcrumb -->
    <div style="margin-bottom: 1.5rem; color: var(--color-gray-600); font-size: 0.875rem;">
      <a href="/" style="color: var(--color-gray-600);">Inicio</a>
      <span style="margin: 0 0.5rem;">›</span>
      <a href="/hechos" style="color: var(--color-gray-600);">Explorar Hechos</a>
      <span style="margin: 0 0.5rem;">›</span>
      <span style="color: var(--color-gray-900); font-weight: 500;">{{hecho.titulo}}</span>
    </div>

    <!-- Card Principal -->
    <div class="card" style="margin-bottom: 2rem;">
      <div class="card-header" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border-bottom: none;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <h2 style="margin: 0; color: white; font-size: 1.75rem;">{{hecho.titulo}}</h2>
          <span class="badge" style="background-color: rgba(255,255,255,0.25); color: white; font-size: 0.875rem; padding: 0.5rem 1rem;">
            {{hecho.categoria}}
          </span>
        </div>
      </div>
      <div class="card-body" style="padding: 2rem;">

        <!-- Descripción -->
        <div style="margin-bottom: 2rem;">
          <h3 style="color: var(--color-gray-900); font-size: 1.25rem; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">
            <span style="font-size: 1.5rem;">📋</span>
            Descripción
          </h3>
          <p style="color: var(--color-gray-700); line-height: 1.6; font-size: 1rem; margin: 0; text-align: justify;">
            {{hecho.descripcion}}
          </p>
        </div>

        <!-- Grid de información -->
        <div class="grid grid-cols-2" style="gap: 2rem; margin-bottom: 2rem;">

          <!-- Columna Izquierda -->
          <div>
            <!-- Fecha -->
            <div style="margin-bottom: 1.5rem; padding: 1rem; background-color: var(--color-gray-50); border-radius: 8px;">
              <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
                <span style="font-size: 1.5rem;">📅</span>
                <h4 style="margin: 0; color: var(--color-gray-700); font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.5px;">Fecha del Hecho</h4>
              </div>
              <p style="margin: 0; color: var(--color-gray-900); font-size: 1.125rem; font-weight: 600; margin-left: 2.25rem;">
                {{hecho.fechaDelHecho}}
              </p>
            </div>

            <!-- Hora -->
            {{#if hecho.horaHecho}}
            <div style="margin-bottom: 1.5rem; padding: 1rem; background-color: var(--color-gray-50); border-radius: 8px;">
              <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
                <span style="font-size: 1.5rem;">🕐</span>
                <h4 style="margin: 0; color: var(--color-gray-700); font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.5px;">Hora</h4>
              </div>
              <p style="margin: 0; color: var(--color-gray-900); font-size: 1.125rem; font-weight: 600; margin-left: 2.25rem;">
                {{hecho.horaHecho}}
              </p>
            </div>
            {{/if}}

            <!-- Origen -->
            <div style="margin-bottom: 1.5rem; padding: 1rem; background-color: var(--color-gray-50); border-radius: 8px;">
              <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
                <span style="font-size: 1.5rem;">🏷️</span>
                <h4 style="margin: 0; color: var(--color-gray-700); font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.5px;">Origen</h4>
              </div>
              <p style="margin: 0; color: var(--color-gray-900); font-size: 1.125rem; font-weight: 600; margin-left: 2.25rem;">
                {{hecho.origen}}
              </p>
            </div>
          </div>

          <!-- Columna Derecha -->
          <div>
            <!-- Ubicación -->
            <div style="margin-bottom: 1.5rem; padding: 1rem; background-color: var(--color-gray-50); border-radius: 8px;">
              <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
                <span style="font-size: 1.5rem;">📍</span>
                <h4 style="margin: 0; color: var(--color-gray-700); font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.5px;">Ubicación</h4>
              </div>
              <div style="margin-left: 2.25rem;">
                {{#if hecho.provincia}}
                <p style="margin: 0; color: var(--color-gray-900); font-size: 1.125rem; font-weight: 600;">
                  {{hecho.provincia}}
                </p>
                {{/if}}
                {{#if hecho.coordenadas.localidad}}
                <p style="margin: 0.25rem 0 0 0; color: var(--color-gray-600); font-size: 0.95rem;">
                  {{hecho.coordenadas.localidad}}
                </p>
                {{/if}}
              </div>
            </div>

            <!-- Coordenadas -->
            {{#if hecho.coordenadas}}
            <div style="margin-bottom: 1.5rem; padding: 1rem; background-color: var(--color-gray-50); border-radius: 8px;">
              <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
                <span style="font-size: 1.5rem;">🌐</span>
                <h4 style="margin: 0; color: var(--color-gray-700); font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.5px;">Coordenadas</h4>
              </div>
              <div style="margin-left: 2.25rem;">
                <p style="margin: 0; color: var(--color-gray-900); font-size: 0.95rem;">
                  <strong>Lat:</strong> {{hecho.coordenadas.latitud}}
                </p>
                <p style="margin: 0.25rem 0 0 0; color: var(--color-gray-900); font-size: 0.95rem;">
                  <strong>Lng:</strong> {{hecho.coordenadas.longitud}}
                </p>
              </div>
            </div>

            <!-- Mapa de Ubicación -->
            <div style="margin-bottom: 1.5rem;">
              <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;">
                <span style="font-size: 1.5rem;">🗺️</span>
                <h4 style="margin: 0; color: var(--color-gray-700); font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.5px;">Mapa de Ubicación</h4>
              </div>
              <div id="detailMap"></div>
            </div>
            {{/if}}

            <!-- Fecha de Creación -->
            <div style="padding: 1rem; background-color: var(--color-gray-50); border-radius: 8px;">
              <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
                <span style="font-size: 1.5rem;">➕</span>
                <h4 style="margin: 0; color: var(--color-gray-700); font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.5px;">Agregado al sistema</h4>
              </div>
              <p style="margin: 0; color: var(--color-gray-900); font-size: 0.95rem; margin-left: 2.25rem;">
                {{hecho.fechaCreacion}}
              </p>
            </div>
          </div>
        </div>

        <!-- Contenido Multimedia (si existe) -->
        {{#if hecho.contenidoMultimedia}}
        <div style="margin-bottom: 1.5rem; padding: 1.5rem; background-color: var(--color-gray-50); border-radius: 8px; border-left: 4px solid var(--color-primary);">
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;">
            <span style="font-size: 1.5rem;">🎬</span>
            <h4 style="margin: 0; color: --color-gray-700); font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.5px;">Contenido Multimedia</h4>
          </div>
          <div id="multimediaContainer" data-url="{{hecho.contenidoMultimedia}}" style="margin-top: 1rem;">
            <!-- El contenido multimedia se cargará dinámicamente con JavaScript -->
          </div>
          <p style="margin-top: 0.5rem; color: var(--color-gray-600); font-size: 0.875rem;">
            <strong>URL:</strong> <a href="{{hecho.contenidoMultimedia}}" target="_blank" style="color: var(--color-primary); word-break: break-all;">{{hecho.contenidoMultimedia}}</a>
          </p>
        </div>
        {{/if}}

        <!-- Acciones -->
        <div style="display: flex; gap: 1rem; margin-top: 2rem; padding-top: 2rem; border-top: 1px solid var(--color-gray-200);">
          <a href="/hechos" class="btn btn-outline">← Volver a la lista</a>
          {{#if user}}
            <button class="btn btn-primary" disabled style="opacity: 0.5; cursor: not-allowed;">
              Editar Hecho (Próximamente)
            </button>
          {{/if}}
        </div>
      </div>
    </div>

    {{#if user}}
    <!-- Card de Solicitud de Eliminación -->
    <div class="card" style="margin-bottom: 2rem; border-left: 3px solid var(--color-warning, #f59e0b);">
      <div class="card-header" style="background-color: rgba(245, 158, 11, 0.05); cursor: pointer;" id="toggleReportForm">
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <h3 class="card-title" style="margin: 0; color: var(--color-warning, #f59e0b); display: flex; align-items: center; gap: 0.5rem;">
            <span style="font-size: 1.5rem;">⚠️</span>
            Reportar Información Incorrecta
          </h3>
          <span id="toggleIcon" style="font-size: 1.5rem; color: var(--color-warning, #f59e0b); transition: transform 0.3s;">▼</span>
        </div>
      </div>
      <div class="card-body" id="reportFormContainer" style="display: none;">

        {{#if errorReporte}}
        <div class="alert alert-error" style="margin-bottom: 1.5rem;">
          <strong>Error:</strong> {{errorReporte}}
        </div>
        {{/if}}

        {{#if exitoReporte}}
        <div class="alert alert-success" style="margin-bottom: 1.5rem; background-color: #d1fae5; border-color: #6ee7b7; color: #065f46;">
          <strong>¡Solicitud enviada!</strong> Tu reporte ha sido recibido y será revisado por un administrador.
        </div>
        {{/if}}

        <form action="/hechos/{{hecho.id}}/reportar" method="POST" id="formReporte">

          <div style="padding: 1rem; background-color: #fef3c7; border-left: 4px solid #f59e0b; border-radius: 4px; margin-bottom: 1.5rem;">
            <p style="margin: 0; color: #78350f; font-size: 0.875rem; line-height: 1.5;">
              <strong>📌 Importante:</strong> Tu solicitud debe incluir una justificación detallada de al menos <strong>500 caracteres</strong>.
              Esto ayuda a los administradores a evaluar correctamente tu reporte y tomar decisiones informadas.
            </p>
          </div>

          <div class="form-group">
            <label class="form-label required" for="justificacion">
              Justificación Detallada
            </label>
            <textarea
              class="form-input"
              id="justificacion"
              name="justificacion"
              placeholder="Por favor, describe en detalle por qué consideras que este hecho debería ser eliminado. Incluye información específica sobre qué datos son incorrectos, duplicados o inapropiados. Cuanto más detallada sea tu explicación, más fácil será para los administradores evaluar tu solicitud..."
              required
              minlength="500"
              rows="8"
              style="resize: vertical; font-family: inherit;"
            ></textarea>
            <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 0.5rem;">
              <small style="color: var(--color-gray-600); font-size: 0.875rem;">
                Sé específico y objetivo en tu descripción
              </small>
              <small id="charCount" style="color: var(--color-gray-500); font-size: 0.875rem; font-weight: 600;">
                0 / 500 caracteres
              </small>
            </div>
          </div>

          <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
            <button type="submit" class="btn" style="flex: 1; background-color: #f59e0b; border-color: #f59e0b; color: white;">
              Enviar Reporte
            </button>
            <button type="button" class="btn btn-outline" style="flex: 1;" onclick="document.getElementById('toggleReportForm').click()">
              Cancelar
            </button>
          </div>
        </form>
      </div>
    </div>
    {{/if}}

    <!-- Card de Información Adicional -->
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">💡 Información Adicional</h3>
      </div>
      <div class="card-body">
        <p style="color: var(--color-gray-600); line-height: 1.6; margin: 0;">
          Este hecho forma parte de la colección colaborativa de MetaMapa. Si encontrás información incorrecta o deseás proponer cambios,
          {{#if user}}
            podés usar el formulario de reporte en esta página.
          {{else}}
            necesitás <a href="/login" style="color: var(--color-primary); font-weight: 500;">iniciar sesión</a> para proponer cambios.
          {{/if}}
        </p>
      </div>
    </div>

  </div>

  <!-- Footer -->
  <div style="background-color: var(--color-gray-800); color: white; padding: 2rem 0; margin-top: 3rem;">
    <div class="container" style="text-align: center;">
      <p style="margin: 0;">MetaMapa - Sistema de gestión de mapeos colaborativos</p>
      <p style="margin: 0.5rem 0 0 0; color: var(--color-gray-400); font-size: 0.875rem;">
        Desarrollado para UTN - Diseño de Sistemas - 2025
      </p>
    </div>
  </div>

  <!-- JavaScript para funcionalidad del formulario de reporte -->
  <script>
    {{#if user}}
    // Toggle del formulario de reporte
    const toggleBtn = document.getElementById('toggleReportForm');
    const formContainer = document.getElementById('reportFormContainer');
    const toggleIcon = document.getElementById('toggleIcon');

    if (toggleBtn && formContainer && toggleIcon) {
      toggleBtn.addEventListener('click', function() {
        const isHidden = formContainer.style.display === 'none';
        formContainer.style.display = isHidden ? 'block' : 'none';
        toggleIcon.style.transform = isHidden ? 'rotate(180deg)' : 'rotate(0deg)';
      });
    }

    // Contador de caracteres
    const textarea = document.getElementById('justificacion');
    const charCount = document.getElementById('charCount');

    if (textarea && charCount) {
      textarea.addEventListener('input', function() {
        const length = this.value.length;
        charCount.textContent = length + ' / 500 caracteres';

        // Cambiar color según progreso
        if (length < 500) {
          charCount.style.color = '#ef4444'; // Rojo si no alcanza
        } else if (length < 1000) {
          charCount.style.color = '#10b981'; // Verde si está en rango óptimo
        } else {
          charCount.style.color = '#6b7280'; // Gris si es muy largo
        }
      });

      // Validación al enviar
      document.getElementById('formReporte').addEventListener('submit', function(e) {
        if (textarea.value.trim().length < 500) {
          e.preventDefault();
          alert('La justificación debe tener al menos 500 caracteres. Actualmente tiene ' + textarea.value.trim().length + ' caracteres.');
          textarea.focus();
        }
      });
    }

    // Si hay error o éxito, mostrar el formulario automáticamente
    {{#if errorReporte}}
    if (formContainer && toggleIcon) {
      formContainer.style.display = 'block';
      toggleIcon.style.transform = 'rotate(180deg)';
    }
    {{/if}}

    {{#if exitoReporte}}
    if (formContainer && toggleIcon) {
      formContainer.style.display = 'block';
      toggleIcon.style.transform = 'rotate(180deg)';
      // Opcional: ocultar el formulario después de mostrar el éxito
      // setTimeout(() => { formContainer.style.display = 'none'; toggleIcon.style.transform = 'rotate(0deg)'; }, 5000);
    }
    {{/if}}
    {{/if}}

    // Renderizar contenido multimedia
    const multimediaContainer = document.getElementById('multimediaContainer');
    if (multimediaContainer) {
      const url = multimediaContainer.dataset.url;
      if (url) {
        // Detectar si es un video de YouTube
        const youtubeRegex = /(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([a-zA-Z0-9_-]{11})/;
        const youtubeMatch = url.match(youtubeRegex);

        if (youtubeMatch) {
          // Es un video de YouTube - crear iframe
          const videoId = youtubeMatch[1];
          multimediaContainer.innerHTML = `
            <div style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; max-width: 100%; background: #000; border-radius: 8px;">
              <iframe
                style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
                src="https://www.youtube.com/embed/${videoId}"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              ></iframe>
            </div>
          `;
        } else if (url.match(/\.(jpeg|jpg|gif|png|webp|svg)$/i)) {
          // Es una imagen - crear elemento img
          multimediaContainer.innerHTML = `
            <div style="text-align: center; max-width: 100%;">
              <img
                src="${url}"
                alt="Contenido multimedia del hecho"
                style="max-width: 100%; height: auto; border-radius: 8px; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);"
                onerror="this.onerror=null; this.parentElement.innerHTML='<p style=\\'color: var(--color-error); text-align: center;\\'>❌ No se pudo cargar la imagen</p>';"
              >
            </div>
          `;
        } else {
          // URL genérica - mostrar enlace
          multimediaContainer.innerHTML = `
            <p style="color: var(--color-gray-600); text-align: center; padding: 1rem; background-color: white; border-radius: 8px;">
              📎 <a href="${url}" target="_blank" style="color: var(--color-primary); font-weight: 500;">Ver contenido multimedia</a>
            </p>
          `;
        }
      }
    }

    // Inicializar mapa de ubicación
    {{#if hecho.coordenadas}}
    const detailMap = L.map('detailMap').setView([{{hecho.coordenadas.latitud}}, {{hecho.coordenadas.longitud}}], 13);

    // Agregar capa de tiles de OpenStreetMap
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      maxZoom: 19
    }).addTo(detailMap);

    // Crear marcador con popup personalizado
    const marker = L.marker([{{hecho.coordenadas.latitud}}, {{hecho.coordenadas.longitud}}]).addTo(detailMap);

    const popupContent = `
      <div style="min-width: 150px; text-align: center;">
        <h4 style="margin: 0 0 0.5rem 0; color: #667eea; font-size: 0.95rem;">
          {{hecho.titulo}}
        </h4>
        <p style="margin: 0; font-size: 0.875rem; color: #4b5563;">
          <span style="display: inline-block; background: #e0e7ff; color: #667eea; padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.75rem; font-weight: 600;">
            {{hecho.categoria}}
          </span>
        </p>
        {{#if hecho.coordenadas.localidad}}
        <p style="margin: 0.5rem 0 0 0; font-size: 0.75rem; color: #6b7280;">
          📍 {{hecho.coordenadas.localidad}}
        </p>
        {{/if}}
      </div>
    `;

    marker.bindPopup(popupContent).openPopup();
    {{/if}}
  </script>
</body>
</html>
