<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Registro - MetaMapa</title>
  <link rel="stylesheet" href="/assets/css/main.css">
</head>
<body>
  <div class="auth-container">
    <div class="auth-card">
      <div style="text-align: center; margin-bottom: 2rem;">
        <h1 class="navbar-brand" style="display: inline-block;">MetaMapa</h1>
      </div>

      <h2 class="auth-title">Crear Cuenta</h2>
      <p class="auth-subtitle">Únete a la comunidad de contribuyentes</p>

      {{#if mensaje}}
        <div class="alert alert-error">
          <strong>Error:</strong> {{mensaje}}
        </div>
      {{/if}}

      <form action="/register" method="POST">
        <div class="form-group">
          <label class="form-label required" for="nombre">Nombre de Usuario</label>
          <input
            type="text"
            class="form-input"
            id="nombre"
            name="nombre"
            placeholder="tu_usuario"
            required
            autofocus
          >
        </div>

        <div class="form-group">
          <label class="form-label required" for="password">Contraseña</label>
          <input
            type="password"
            class="form-input"
            id="password"
            name="password"
            placeholder="••••••••"
            minlength="8"
            required
          >
          <span class="form-help">Mínimo 8 caracteres</span>
        </div>

        <div class="form-group">
          <label class="form-label required" for="passwordConfirm">Confirmar Contraseña</label>
          <input
            type="password"
            class="form-input"
            id="passwordConfirm"
            name="passwordConfirm"
            placeholder="••••••••"
            required
          >
        </div>

        <button type="submit" class="btn btn-primary w-full">Crear Cuenta</button>
      </form>

      <div style="margin-top: 1.5rem; text-align: center; padding-top: 1.5rem; border-top: 1px solid var(--color-gray-200);">
        <p style="color: var(--color-gray-600); font-size: 0.875rem;">
          ¿Ya tienes cuenta? <a href="/login" style="color: var(--color-primary); font-weight: 500;">Inicia sesión aquí</a>
        </p>
        <p style="margin-top: 0.5rem;">
          <a href="/" style="color: var(--color-gray-600); font-size: 0.875rem;">← Volver al inicio</a>
        </p>
      </div>
    </div>
  </div>
</body>
</html>
